# The Odds API — https://the-odds-api.com (free tier: 500 req/month)
# Includes Pinnacle, Bet365, DraftKings and other sharp books
ODDS_API_KEY=your_key_here

# Kalshi — https://kalshi.com/api (requires account)
KALSHI_API_KEY=your_key_here
KALSHI_API_KEY_ID=your_key_id_here

# Polymarket — no auth required for public markets, optional for higher limits
# POLYMARKET_API_KEY=

# EV threshold to surface opportunities (default 3%)
EV_THRESHOLD=0.03

LOG_LEVEL=INFO
